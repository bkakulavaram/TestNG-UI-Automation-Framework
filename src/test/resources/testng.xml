<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Enterprise Suite" parallel="tests" thread-count="3">

    <listeners>
        <listener class-name="com.qa.automation.framework.Listeners.TestListener"/>
        <listener class-name="com.qa.automation.framework.Listeners.AllureListener"/>
    </listeners>

    <test name="UI Tests">
        <classes>
            <class name="com.qa.automation.tests.LoginTest"/>
            <class name="com.qa.automation.tests.RegisterTest"/>
            <class name="com.qa.automation.tests.E2ETest"/>

        </classes>
    </test>

</suite>